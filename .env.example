# Скопируйте в .env и заполните

# Пароль для входа в приложение (обязательно; без него вход закрыт)
APP_PASSWORD=

# Секрет для подписи сессионных cookie (любая случайная строка, например `openssl rand -hex 32`)
AUTH_SECRET=

# API-ключ TronGrid для проверки балансов (опционально, но без него жёсткий rate limit)
TRONGRID_API_KEY=

# Ключ KuCoin (v2) для чтения балансов аккаунта. Достаточно права General (только чтение).
# Passphrase — та строка, что задана при создании ключа.
KUCOIN_API_KEY=
KUCOIN_API_SECRET=
KUCOIN_API_PASSPHRASE=
# Базовый URL API (опционально, по умолчанию https://api.kucoin.com)
# KUCOIN_API_URL=https://api.kucoin.com

# Ключ Bitget для чтения балансов аккаунта — достаточно права Read-only.
# Для пополнения кошельков TRX с биржи (вывод) нужен ключ с правом Withdraw,
# а адрес получателя, как правило, должен быть в whitelist Bitget (+ IP-allowlist).
# Passphrase — та строка, что задана при создании ключа.
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSPHRASE=
# Базовый URL API (опционально, по умолчанию https://api.bitget.com)
# BITGET_API_URL=https://api.bitget.com

# Прокси со статическим IP для запросов к биржам (Bitget/KuCoin).
# Нужен на Vercel: у serverless нет фиксированного исходящего IP, а право Withdraw
# на ключе Bitget требует IP в whitelist. Впишите IP этого прокси в whitelist ключа.
# Через прокси идут ТОЛЬКО биржи (TronGrid/Telegram/БД — напрямую).
# Не задан -> прямой fetch (нормальный режим локальной разработки).
# Формат: [http|https]://[user:pass@]host:port . См. DEPLOY.md.
# EXCHANGE_PROXY_URL=https://user:pass@1.2.3.4:8443
#
# Для HTTPS-прокси с самоподписанным сертификатом (свой VPS по голому IP):
#   EXCHANGE_PROXY_CA          — PEM сертификата прокси (пиннинг). Одной строкой со
#                                \n вместо переносов, либо многострочным значением.
#   EXCHANGE_PROXY_SERVERNAME  — DNS-метка из SAN сертификата (напр. depo-proxy):
#                                undici не ставит SNI на IP, TLS проверяется по метке.
# EXCHANGE_PROXY_CA="-----BEGIN CERTIFICATE-----\nMIID...\n-----END CERTIFICATE-----\n"
# EXCHANGE_PROXY_SERVERNAME=depo-proxy

# Секрет для эндпоинта ежедневного снимка TRX (/api/cron/snapshot), любая случайная
# строка, например `openssl rand -hex 32`. На Vercel имя CRON_SECRET зарезервировано:
# платформа сама шлёт его в заголовке Authorization: Bearer при вызове крона.
CRON_SECRET=

# --- Telegram-бот для заведения долгов ---
# Токен бота от @BotFather. Без него бот не работает.
TELEGRAM_BOT_TOKEN=
# Секрет вебхука (любая случайная строка, например `openssl rand -hex 32`).
# Передаётся в setWebhook и сверяется с заголовком X-Telegram-Bot-Api-Secret-Token.
TELEGRAM_WEBHOOK_SECRET=
# Ваш chat id в Telegram (узнать: @userinfobot). Бот отвечает только этому чату.
TELEGRAM_OWNER_CHAT_ID=
# Ключ Anthropic для разбора текста заявок (LLM). Без него — запасной regex-разбор.
ANTHROPIC_API_KEY=
# Модель для разбора (опционально, по умолчанию claude-opus-4-8)
# TELEGRAM_PARSE_MODEL=claude-opus-4-8

# --- База данных ---
# Прод (Vercel + Turso): задайте обе переменные — приложение пойдёт в Turso.
# Локально их можно НЕ задавать: тогда используется файл SQLite (см. DB_PATH ниже).
# Получить: `turso db show <db> --url` и `turso db tokens create <db>`. См. DEPLOY.md.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Путь к локальному файлу SQLite (используется, только если TURSO_* не заданы;
# по умолчанию ./data/depo.db)
# DB_PATH=./data/depo.db
